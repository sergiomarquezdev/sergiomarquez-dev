---
import type { CvData } from "../../data/cv";
import type { Locale } from "../../i18n";
import { t } from "../../i18n/index";
import DotGrid from "../ui/DotGrid.astro";

interface Props {
	basics: CvData["basics"];
	locale: Locale;
}
const { basics, locale } = Astro.props;

const fullHeadline = basics.headline ?? basics.tagline;
const accentSuffix = basics.headlineAccent;
const headlineLead =
	accentSuffix && fullHeadline.endsWith(accentSuffix)
		? fullHeadline.slice(0, -accentSuffix.length).trimEnd()
		: fullHeadline;
const headlineAccentText =
	accentSuffix && fullHeadline.endsWith(accentSuffix) ? accentSuffix : null;

const stack = basics.stackChips ?? [];
const status = basics.status;
const ctaPrimary = t(locale, "footer.contact");
const ctaSecondary = locale === "en" ? "See work" : "Ver work";
const titlebar = "sergio@dev — ~/portfolio";
---
<section class="hero" aria-labelledby="hero-headline">
  <DotGrid />
  <div class="hero__window term-window">
    <div class="term-titlebar">
      <span class="term-dots" aria-hidden="true"><span></span><span></span><span></span></span>
      <span class="term-title">{titlebar}</span>
    </div>

    <div class="hero__body">
      <p class="term-line hero__cmd">
        <span class="tok-prompt">sergio@dev</span> <span class="tok-path">~</span>
        <span class="tok-comment">%</span> whoami
      </p>

      <p class="hero__role term-line">
        <span class="hero__role-name">{basics.name}</span>
        <span class="tok-comment"> · {t(locale, "hero.role")}</span>
      </p>

      <h1 id="hero-headline" class="hero__headline">
        {headlineLead}
        {headlineAccentText && (
          <>
            {" "}
            <span class="hero__headline-accent">{headlineAccentText}</span>
          </>
        )}<span class="caret caret--blink" aria-hidden="true"></span>
      </h1>

      {status && (
        <p class="term-line hero__now">
          <span class="tok-prompt">&gt;</span> cat ~/.now
          <span class="hero__now-out">
            {status.available && <span class="hero__dot" aria-hidden="true"></span>}
            {status.label}
          </span>
        </p>
      )}

      <p class="term-line hero__proof">
        <span class="tok-prompt">&gt;</span> ls ./proof
        <span class="hero__proof-out">{t(locale, "hero.proof")}</span>
      </p>

      {stack.length > 0 && (
        <ul class="hero__stack" aria-label="Stack">
          {stack.map((s) => <li class="hero__chip">{s}</li>)}
        </ul>
      )}

      <div class="hero__ctas">
        <a class="term-btn term-btn--accent" href={`mailto:${basics.email}`}>{ctaPrimary} →</a>
        <a class="term-btn" href="#cases">{ctaSecondary} ↓</a>
        <button type="button" class="term-btn hero__cmdk" data-cmdk-open aria-haspopup="dialog">
          <kbd class="kbd">⌘K</kbd>
          <span>{t(locale, "cmdk.hint")}</span>
        </button>
      </div>
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    padding: clamp(1rem, 4vw, 2.5rem) 0 clamp(2.5rem, 5vw, 4rem);
    isolation: isolate;
    /* Clip the DotGrid bleed (width:160%) and radial glow so they never
       create page-wide horizontal scroll. The dot mask already fades to
       transparent before the box edge, so clipping is visually lossless. */
    overflow: hidden;
  }
  .hero::before {
    content: "";
    position: absolute;
    inset: -10% -20% auto -20%;
    height: 70%;
    background: radial-gradient(ellipse 70% 60% at 50% 25%, var(--accent-glow), transparent 70%);
    pointer-events: none;
    z-index: -1;
  }
  .hero__window {
    position: relative;
    z-index: 1;
    max-width: 56rem;
  }
  .hero__body {
    padding: clamp(1.25rem, 3vw, 2.25rem);
    display: flex;
    flex-direction: column;
    gap: 0.85rem;
  }
  .hero__cmd {
    margin: 0;
    color: var(--text-secondary);
  }
  .hero__role {
    margin: 0;
  }
  .hero__role-name {
    color: var(--text-primary);
  }
  .hero__headline {
    font-family: var(--font-sans);
    font-weight: 600;
    font-size: clamp(2.1rem, 5.5vw, 3.9rem);
    line-height: 1.04;
    letter-spacing: -0.025em;
    color: var(--text-primary);
    margin: 0.35rem 0 0.5rem;
    text-wrap: balance;
  }
  .hero__headline-accent {
    font-family: var(--font-serif);
    font-style: italic;
    font-weight: 400;
    color: var(--accent);
    letter-spacing: -0.01em;
  }
  .hero__now,
  .hero__proof {
    margin: 0;
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    gap: 0.5rem;
    color: var(--text-tertiary);
  }
  .hero__now-out,
  .hero__proof-out {
    color: var(--text-secondary);
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
  }
  .hero__dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background-color: var(--accent);
    box-shadow: 0 0 0 3px var(--accent-muted);
    flex-shrink: 0;
  }
  .hero__stack {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    list-style: none;
    padding: 0;
    margin: 0.5rem 0 0.25rem;
  }
  .hero__chip {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--accent-text);
    padding: 0.2rem 0.55rem;
    border: 1px solid var(--border-accent);
    border-radius: 999px;
    background-color: var(--accent-muted);
  }
  .hero__ctas {
    display: flex;
    flex-wrap: wrap;
    gap: 0.6rem;
    margin-top: 0.85rem;
  }
  .hero__cmdk {
    color: var(--text-tertiary);
  }
  @media (max-width: 540px) {
    .hero__cmdk {
      display: none;
    }
  }
</style>
