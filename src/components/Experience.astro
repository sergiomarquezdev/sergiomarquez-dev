---
import type { CvData } from "../data/cv";
import { getLocale, t } from "../i18n/index";

interface Props {
	experience: CvData["experience"];
}

const { experience } = Astro.props;
const locale = getLocale(Astro.currentLocale);
const MAX_HIGHLIGHTS = 3;

function isCurrent(period: string): boolean {
	return /present|presente/i.test(period);
}
---

<div class="experience">
  <h2 class="section-title">{t(locale, "section.experience")}</h2>
  <div class="timeline">
    {experience.map((role, index) => (
      <div class="timeline-item">
        <div class="timeline-track">
          <span class:list={["timeline-dot", { "timeline-dot--current": isCurrent(role.period) }]} />
          {index < experience.length - 1 && <span class="timeline-line" />}
        </div>
        <div class="role-card card-interactive">
          <header class="role-header">
            <span class="role-period">{role.period}</span>
            <div class="role-info">
              <h3 class="role-title">
                {role.role}
                <span class="role-separator">&ndash;</span>
                <span class="role-company">{role.company}</span>
              </h3>
              <p class="role-summary">{role.summary}</p>
              <ul class="role-highlights">
                {role.highlights.slice(0, MAX_HIGHLIGHTS).map((item) => (
                  <li>{item}</li>
                ))}
              </ul>
            </div>
          </header>
        </div>
      </div>
    ))}
  </div>
</div>

<style>
  .experience {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .timeline {
    display: flex;
    flex-direction: column;
  }

  .timeline-item {
    display: flex;
    gap: 0;
  }

  .timeline-track {
    display: none;
  }

  @media (min-width: 640px) {
    .timeline-track {
      display: flex;
      flex-direction: column;
      align-items: center;
      width: 1.5rem;
      flex-shrink: 0;
      padding-top: 1.25rem;
    }
  }

  .timeline-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background-color: var(--surface-alt);
    flex-shrink: 0;
    z-index: 1;
  }

  .timeline-dot--current {
    background-color: var(--accent);
    animation: pulse 2s ease-in-out infinite;
  }

  .timeline-line {
    width: 2px;
    flex-grow: 1;
    background-color: var(--surface-alt);
  }

  .role-card {
    padding: 1rem 1.5rem;
    cursor: default;
    flex: 1;
    min-width: 0;
  }

  .role-header {
    display: grid;
    grid-template-columns: 1fr;
    gap: 0.5rem;
  }

  @media (min-width: 640px) {
    .role-header {
      grid-template-columns: 140px 1fr;
      gap: 1rem;
    }
  }

  .role-period {
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.02em;
    text-transform: uppercase;
    color: var(--tertiary-text);
    padding-top: 0.25rem;
    font-variant-numeric: lining-nums tabular-nums;
  }

  .role-info {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .role-title {
    margin: 0;
    font-size: 1rem;
    font-weight: 500;
    color: var(--primary-text);
    line-height: 1.4;
    transition: color 0.2s ease-in-out;
  }

  .role-card:hover .role-title {
    color: var(--accent);
  }

  .role-separator {
    color: var(--tertiary-text);
    margin: 0 0.25rem;
  }

  .role-company {
    color: var(--secondary-text);
    font-weight: 400;
  }

  .role-summary {
    margin: 0;
    font-size: 0.875rem;
    line-height: 1.6;
    color: var(--secondary-text);
  }

  .role-highlights {
    margin: 0.5rem 0 0 0;
    padding-left: 1rem;
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
    color: var(--secondary-text);
    font-size: 0.8rem;
    line-height: 1.5;
  }

  .role-highlights li {
    padding-left: 0.25rem;
  }

  .role-highlights li::marker {
    color: var(--accent);
  }
</style>
