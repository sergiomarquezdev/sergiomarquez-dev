---
import type { CvData } from "../data/cv";
import { getLocale, t } from "../i18n/index";

interface Props {
	basics: CvData["basics"];
}

const { basics } = Astro.props;
const locale = getLocale(Astro.currentLocale);
const otherHome = locale === "en" ? "/" : "/en/";

// Each command is fully usable via keyboard or pointer; everything here is also
// reachable through normal scroll + links elsewhere on the page (no lock-in).
const navCommands = [
	{ label: t(locale, "nav.about"), action: "anchor", value: "#about", glyph: "→" },
	{ label: t(locale, "nav.cases"), action: "anchor", value: "#cases", glyph: "→" },
	{ label: t(locale, "nav.projects"), action: "anchor", value: "#projects", glyph: "→" },
	{ label: t(locale, "nav.writing"), action: "anchor", value: "#writing", glyph: "→" },
	{ label: t(locale, "nav.contact"), action: "anchor", value: "#contact", glyph: "→" },
];

const linkCommands = [
	{ label: t(locale, "cmdk.openGithub"), action: "url", value: basics.urls.github, glyph: "↗" },
	{ label: t(locale, "cmdk.openLinkedin"), action: "url", value: basics.urls.linkedin, glyph: "↗" },
	...(basics.urls.blog
		? [{ label: t(locale, "cmdk.openBlog"), action: "url", value: basics.urls.blog, glyph: "↗" }]
		: []),
	{ label: t(locale, "cmdk.openX"), action: "url", value: basics.urls.x, glyph: "↗" },
];

const actionCommands = [
	{ label: t(locale, "cmdk.toggleLang"), action: "lang", value: otherHome, glyph: "⇄" },
	{ label: t(locale, "cmdk.copyEmail"), action: "copy", value: basics.email, glyph: "⎘" },
];

const groups = [
	{ title: t(locale, "cmdk.groupNav"), items: navCommands },
	{ title: t(locale, "cmdk.groupLinks"), items: linkCommands },
	{ title: t(locale, "cmdk.groupActions"), items: actionCommands },
];
---

<dialog
  class="cmdk"
  id="cmdk"
  aria-label={t(locale, "cmdk.placeholder")}
  data-copied={t(locale, "cmdk.copied")}
>
  <div class="cmdk__panel term-window">
    <div class="cmdk__inputrow">
      <span class="tok-prompt" aria-hidden="true">&gt;</span>
      <input
        type="text"
        class="cmdk__input"
        id="cmdk-input"
        placeholder={t(locale, "cmdk.placeholder")}
        autocomplete="off"
        autocorrect="off"
        autocapitalize="off"
        spellcheck="false"
      />
      <kbd class="kbd">esc</kbd>
    </div>
    <ul class="cmdk__list" id="cmdk-list" role="listbox" aria-label={t(locale, "cmdk.placeholder")}>
      {groups.map((group) => (
        <li class="cmdk__group" role="presentation">
          <p class="cmdk__grouptitle">{group.title}</p>
          <ul role="presentation">
            {group.items.map((item) => (
              <li role="presentation">
                <button
                  type="button"
                  class="cmdk__item"
                  role="option"
                  aria-selected="false"
                  data-action={item.action}
                  data-value={item.value}
                  data-label={item.label.toLowerCase()}
                >
                  <span class="cmdk__glyph" aria-hidden="true">{item.glyph}</span>
                  <span class="cmdk__label">{item.label}</span>
                </button>
              </li>
            ))}
          </ul>
        </li>
      ))}
      <li class="cmdk__empty" id="cmdk-empty" hidden>{t(locale, "cmdk.empty")}</li>
    </ul>
  </div>
</dialog>

<script>
  function initCommandPalette() {
    const dialogEl = document.getElementById("cmdk");
    const inputEl = document.getElementById("cmdk-input");
    const listEl = document.getElementById("cmdk-list");
    const emptyEl = document.getElementById("cmdk-empty");
    if (
      !(dialogEl instanceof HTMLDialogElement) ||
      !(inputEl instanceof HTMLInputElement) ||
      !(listEl instanceof HTMLElement)
    ) {
      return;
    }
    setupCommandPalette(dialogEl, inputEl, listEl, emptyEl);
  }

  function setupCommandPalette(
    dialog: HTMLDialogElement,
    input: HTMLInputElement,
    list: HTMLElement,
    empty: HTMLElement | null,
  ) {
    const items = () =>
      Array.from(dialog.querySelectorAll<HTMLButtonElement>(".cmdk__item:not([hidden])"));

    let activeIndex = 0;

    function setActive(index: number) {
      const visible = items();
      if (visible.length === 0) return;
      activeIndex = (index + visible.length) % visible.length;
      visible.forEach((el, i) => {
        const isActive = i === activeIndex;
        el.setAttribute("aria-selected", isActive ? "true" : "false");
        el.classList.toggle("is-active", isActive);
        if (isActive) el.scrollIntoView({ block: "nearest" });
      });
    }

    function open() {
      if (dialog.open) return;
      input.value = "";
      filter();
      dialog.showModal();
      activeIndex = 0;
      setActive(0);
      requestAnimationFrame(() => input.focus());
    }

    function close() {
      if (dialog.open) dialog.close();
    }

    function filter() {
      const q = input.value.trim().toLowerCase();
      let anyVisible = false;
      dialog.querySelectorAll<HTMLButtonElement>(".cmdk__item").forEach((el) => {
        const label = el.dataset.label ?? "";
        const match = q === "" || label.includes(q);
        el.toggleAttribute("hidden", !match);
        if (match) anyVisible = true;
      });
      // Hide group titles whose items are all filtered out
      dialog.querySelectorAll<HTMLElement>(".cmdk__group").forEach((group) => {
        const hasVisible = group.querySelector(".cmdk__item:not([hidden])") !== null;
        group.toggleAttribute("hidden", !hasVisible);
      });
      if (empty) empty.toggleAttribute("hidden", anyVisible);
      activeIndex = 0;
      setActive(0);
    }

    function run(el: HTMLButtonElement) {
      const action = el.dataset.action;
      const value = el.dataset.value ?? "";
      close();
      switch (action) {
        case "anchor": {
          const target = document.querySelector(value);
          if (target) {
            target.scrollIntoView({ behavior: "smooth", block: "start" });
            history.replaceState(null, "", value);
          }
          break;
        }
        case "url":
          window.open(value, "_blank", "noopener,noreferrer");
          break;
        case "lang":
          window.location.href = value;
          break;
        case "copy":
          navigator.clipboard?.writeText(value).then(() => {
            announce(dialog.dataset.copied ?? "");
          });
          break;
      }
    }

    function announce(message: string) {
      if (!message) return;
      let toast = document.getElementById("cmdk-toast");
      if (!toast) {
        toast = document.createElement("div");
        toast.id = "cmdk-toast";
        toast.className = "cmdk__toast";
        toast.setAttribute("role", "status");
        document.body.appendChild(toast);
      }
      toast.textContent = message;
      toast.classList.add("is-visible");
      window.setTimeout(() => toast?.classList.remove("is-visible"), 1600);
    }

    // Open triggers: Cmd/Ctrl+K from anywhere, or "/" when not already typing.
    document.addEventListener("keydown", (e) => {
      const target = e.target as HTMLElement | null;
      const typing =
        target &&
        (target.tagName === "INPUT" ||
          target.tagName === "TEXTAREA" ||
          target.isContentEditable);
      if ((e.key === "k" || e.key === "K") && (e.metaKey || e.ctrlKey)) {
        e.preventDefault();
        dialog.open ? close() : open();
      } else if (e.key === "/" && !typing && !dialog.open) {
        e.preventDefault();
        open();
      }
    });

    // Discoverable triggers (chips / buttons elsewhere in the UI)
    document.querySelectorAll<HTMLElement>("[data-cmdk-open]").forEach((trigger) => {
      trigger.addEventListener("click", (e) => {
        e.preventDefault();
        open();
      });
    });

    input.addEventListener("input", filter);

    dialog.addEventListener("keydown", (e) => {
      if (e.key === "ArrowDown") {
        e.preventDefault();
        setActive(activeIndex + 1);
      } else if (e.key === "ArrowUp") {
        e.preventDefault();
        setActive(activeIndex - 1);
      } else if (e.key === "Enter") {
        e.preventDefault();
        const visible = items();
        if (visible[activeIndex]) run(visible[activeIndex]);
      }
    });

    list.addEventListener("click", (e) => {
      const btn = (e.target as HTMLElement).closest<HTMLButtonElement>(".cmdk__item");
      if (btn) run(btn);
    });

    // Click on backdrop closes
    dialog.addEventListener("click", (e) => {
      if (e.target === dialog) close();
    });
  }

  document.addEventListener("astro:page-load", initCommandPalette);
  initCommandPalette();
</script>

<style>
  .cmdk {
    margin: 0 auto;
    padding: 0;
    border: none;
    background: transparent;
    max-width: 560px;
    width: calc(100% - 2rem);
    top: 12vh;
    color: var(--text-primary);
  }

  .cmdk::backdrop {
    background-color: rgba(10, 10, 11, 0.72);
  }

  .cmdk__panel {
    display: flex;
    flex-direction: column;
    max-height: 70vh;
  }

  .cmdk__inputrow {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    padding: 0.85rem 1rem;
    border-bottom: 1px solid var(--border);
  }

  .cmdk__inputrow .tok-prompt {
    font-family: var(--font-mono);
    font-size: 1rem;
  }

  .cmdk__input {
    flex: 1;
    background: transparent;
    border: none;
    outline: none;
    color: var(--text-primary);
    font-family: var(--font-mono);
    font-size: 0.95rem;
  }

  .cmdk__input::placeholder {
    color: var(--text-tertiary);
  }

  .cmdk__list {
    list-style: none;
    margin: 0;
    padding: 0.5rem;
    overflow-y: auto;
  }

  .cmdk__group {
    margin-bottom: 0.35rem;
  }

  .cmdk__group ul {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .cmdk__grouptitle {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--text-tertiary);
    margin: 0.5rem 0.65rem 0.25rem;
  }

  .cmdk__item {
    display: flex;
    align-items: center;
    gap: 0.7rem;
    width: 100%;
    padding: 0.55rem 0.65rem;
    background: transparent;
    border: 1px solid transparent;
    border-radius: 7px;
    color: var(--text-secondary);
    font-family: var(--font-sans);
    font-size: 0.9rem;
    text-align: left;
    cursor: pointer;
  }

  .cmdk__item:hover,
  .cmdk__item.is-active {
    background-color: var(--accent-muted);
    border-color: var(--border-accent);
    color: var(--text-primary);
  }

  .cmdk__glyph {
    font-family: var(--font-mono);
    color: var(--accent);
    width: 1.1rem;
    text-align: center;
    flex-shrink: 0;
  }

  .cmdk__empty {
    list-style: none;
    padding: 1.25rem;
    text-align: center;
    color: var(--text-tertiary);
    font-family: var(--font-mono);
    font-size: 0.85rem;
  }
</style>

<style is:global>
  .cmdk__toast {
    position: fixed;
    bottom: 1.5rem;
    left: 50%;
    translate: -50% 0;
    z-index: 200;
    padding: 0.55rem 0.95rem;
    background-color: var(--bg-elevated);
    border: 1px solid var(--border-accent);
    border-radius: 7px;
    color: var(--accent);
    font-family: var(--font-mono);
    font-size: 0.85rem;
    opacity: 0;
    pointer-events: none;
    transition: opacity 200ms ease;
  }

  .cmdk__toast.is-visible {
    opacity: 1;
  }

  @media (prefers-reduced-motion: reduce) {
    .cmdk__toast {
      transition: none;
    }
  }
</style>
