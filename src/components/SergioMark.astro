---
type Variant = "universal" | "square" | "mini" | "lockup";

interface Props {
	variant?: Variant;
	class?: string;
	width?: number | string;
	height?: number | string;
	ariaLabel?: string;
}

const {
	variant = "universal",
	class: className,
	width,
	height,
	ariaLabel = "Sergio Márquez",
