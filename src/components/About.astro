---
import type { CvData } from "../data/cv";
import { getLocale } from "../i18n";

interface Props {
	basics: CvData["basics"];
}
const { basics } = Astro.props;
const locale = getLocale(Astro.currentLocale);
const title =
	locale === "en" ? "From backend to building with agents" : "Del backend a construir con agentes";
const alsoRunningPrefix = locale === "en" ? "I also run" : "También dirijo";
---
<section class="about" aria-labelledby="about-title">
  <header class="about__head">
    <p class="about__eyebrow"><span class="tok-prompt">~ %</span> cat about.md</p>
    <h2 id="about-title" class="about__title">{title}</h2>
  </header>
  <p class="about__body">{basics.summary}</p>
  {basics.alsoRunning && (
    <p class="about__also">
      {alsoRunningPrefix}{" "}
      <a class="about__also-link" href={basics.alsoRunning.url} target="_blank" rel="noopener noreferrer">
        {basics.alsoRunning.name}
      </a>
      , {basics.alsoRunning.description}.
    </p>
  )}
</section>

<style>
  .about {
    padding: clamp(3rem, 6vw, 5rem) 0;
    max-width: 56rem;
  }
  .about__head { margin-bottom: 1.5rem; }
  .about__eyebrow {
    font-family: var(--font-mono);
    font-size: 0.8125rem;
    letter-spacing: 0;
    color: var(--text-tertiary);
    margin: 0 0 0.6rem;
  }
  .about__eyebrow .tok-prompt {
    color: var(--accent);
  }
  .about__title {
    font-family: var(--font-serif);
    font-size: clamp(1.875rem, 4vw, 2.75rem);
    font-weight: 400;
    color: var(--text-primary);
    margin: 0;
    line-height: 1.1;
    letter-spacing: -0.01em;
  }
  .about__body {
    font-family: var(--font-sans);
    font-size: var(--text-lg);
    line-height: 1.7;
    color: var(--text-secondary);
    margin: 0;
  }
  .about__also {
    font-family: var(--font-sans);
    font-size: 0.9375rem;
    line-height: 1.6;
    color: var(--text-tertiary);
    margin: 1rem 0 0;
  }
  .about__also-link {
    color: var(--text-secondary);
    text-decoration: underline;
    text-decoration-color: var(--border-strong);
    text-underline-offset: 0.2em;
    transition: color 200ms ease, text-decoration-color 200ms ease;
  }
  .about__also-link:hover {
    color: var(--accent);
    text-decoration-color: var(--accent);
  }
</style>
