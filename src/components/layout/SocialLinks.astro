---
import type { CvData } from "../../data/cv";
import BlogIcon from "../icons/BlogIcon.astro";
import GitHubIcon from "../icons/GitHubIcon.astro";
import InstagramIcon from "../icons/InstagramIcon.astro";
import LinkedInIcon from "../icons/LinkedInIcon.astro";
import TikTokIcon from "../icons/TikTokIcon.astro";
import XIcon from "../icons/XIcon.astro";
import YouTubeIcon from "../icons/YouTubeIcon.astro";

interface Props {
	urls: CvData["basics"]["urls"];
}

const { urls } = Astro.props;

const links = [
	{ href: urls.github, label: "GitHub", Icon: GitHubIcon },
	{ href: urls.linkedin, label: "LinkedIn", Icon: LinkedInIcon },
	{ href: urls.youtube, label: "YouTube", Icon: YouTubeIcon },
	{ href: urls.tiktok, label: "TikTok", Icon: TikTokIcon },
	{ href: urls.instagram, label: "Instagram", Icon: InstagramIcon },
	{ href: urls.x, label: "X (Twitter)", Icon: XIcon },
	{ href: urls.blog, label: "Blog", Icon: BlogIcon },
].filter((link) => link.href);
---

<ul class="social-links">
  {links.map(({ href, label, Icon }) => (
    <li>
      <a
        href={href}
        class="social-link"
        aria-label={label}
        target="_blank"
        rel="noopener noreferrer"
      >
        <Icon class="icon" />
      </a>
    </li>
  ))}
</ul>

<style>
  .social-links {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .social-link {
    color: var(--text-secondary);
    background-color: transparent;
    border: 1px solid var(--border);
    border-radius: 999px;
    width: 2.25rem;
    height: 2.25rem;
    display: grid;
    place-items: center;
    transition:
      color 0.2s ease-in-out,
      border-color 0.2s ease-in-out,
      background-color 0.2s ease-in-out;
  }

  .social-link:hover {
    color: var(--text-primary);
    border-color: var(--border-strong);
    background-color: var(--bg-elevated);
  }

  .icon {
    width: 1rem;
    height: 1rem;
  }

  @media (max-width: 1023.98px) {
    .social-link {
      width: 2.75rem;
      height: 2.75rem;
    }

    .icon {
      width: 1.125rem;
      height: 1.125rem;
    }
  }
</style>
