---
import { getLocale, t } from "../../i18n/index";

const locale = getLocale(Astro.currentLocale);

interface NavItem {
	id: string;
	label: string;
}

const navItems: NavItem[] = [
	{ id: "about", label: t(locale, "nav.about") },
	{ id: "cases", label: t(locale, "nav.cases") },
	{ id: "projects", label: t(locale, "nav.projects") },
	{ id: "writing", label: t(locale, "nav.writing") },
	{ id: "certifications", label: t(locale, "nav.certifications") },
	{ id: "contact", label: t(locale, "nav.contact") },
];
---

<nav class="navigation" aria-label={t(locale, "aria.mainNav")}>
  <ul class="nav-list">
    {
      navItems.map((item) => (
        <li>
          <a href={`#${item.id}`} class="nav-link" data-section={item.id}>
            <span class="nav-indicator" />
            <span class="nav-cmd"><span class="nav-kw">cd</span> ~/{item.id}</span>
            <span class="nav-comment"># {item.label}</span>
          </a>
        </li>
      ))
    }
  </ul>
</nav>

<script>
  import { initScrollSpy } from "../../scripts/scrollSpy";

  initScrollSpy({
    linkSelector: ".nav-link",
    getSectionId: (link) => link.dataset.section,
    setAriaCurrent: true,
  });
</script>

<style>
  .navigation {
    display: none;
  }

  @media (min-width: 1024px) {
    .navigation {
      display: block;
    }
  }

  .nav-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .nav-link {
    display: flex;
    align-items: baseline;
    gap: 0.7rem;
    padding: 0.3rem 0;
    color: var(--text-secondary);
    font-family: var(--font-mono);
    font-size: 0.8125rem;
    font-weight: 500;
    letter-spacing: 0;
    transition: color 0.2s ease-in-out;
  }

  .nav-kw {
    color: var(--accent);
  }

  .nav-comment {
    color: var(--text-tertiary);
    opacity: 0;
    transition: opacity 0.2s ease-in-out;
  }

  .nav-link:hover,
  .nav-link.active {
    color: var(--text-primary);
  }

  .nav-link:hover .nav-comment,
  .nav-link.active .nav-comment {
    opacity: 1;
  }

  .nav-link:hover .nav-indicator {
    width: 1.6rem;
    background-color: var(--text-secondary);
  }

  .nav-link.active .nav-indicator {
    width: 1.6rem;
    background-color: var(--accent);
  }

  .nav-indicator {
    align-self: center;
    width: 0.7rem;
    height: 1px;
    background-color: var(--border-strong);
    flex-shrink: 0;
    transition:
      width 0.2s ease-in-out,
      background-color 0.2s ease-in-out;
  }
</style>
