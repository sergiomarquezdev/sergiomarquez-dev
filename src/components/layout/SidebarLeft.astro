---
import type { CvData } from "../../data/cv";
import { getLocale, t } from "../../i18n/index";
import GitHubActivity from "../GitHubActivity.astro";
import LanguageSwitcher from "../LanguageSwitcher.astro";
import SergioMark from "../SergioMark.astro";
import Navigation from "./Navigation.astro";
import SocialLinks from "./SocialLinks.astro";

interface Props {
	basics: CvData["basics"];
}

const { basics } = Astro.props;
const locale = getLocale(Astro.currentLocale);
const homeHref = locale === "en" ? "/en/" : "/";
---

<header class="sidebar-left">
  <div class="sidebar-content">
    <div class="header-section">
        <a href={homeHref} class="logo-link" aria-hidden="true" tabindex="-1">
          <SergioMark variant="square" class="logo-mark" width={36} height={36} />
        </a>
        <h1 class="name">
          <a href={homeHref}>{basics.name}</a>
        </h1>
        <p class="whoami">
          <span class="tok-prompt">$</span> whoami
        </p>
        <p class="tagline"><span class="tok-comment"># </span>{basics.tagline}</p>
        <GitHubActivity />
      </div>

    <Navigation />

    <div class="footer-section">
      <button type="button" class="sb-cmdk" data-cmdk-open aria-haspopup="dialog">
        <kbd class="kbd">⌘K</kbd>
        <span>{t(locale, "cmdk.hint")}</span>
      </button>
      <div class="footer-row">
        <SocialLinks urls={basics.urls} />
        <LanguageSwitcher />
      </div>
    </div>
  </div>
</header>

<style>
  .sidebar-left {
    display: none;
  }

  @media (min-width: 1024px) {
    .sidebar-left {
      display: flex;
      flex-direction: column;
      justify-content: space-between;
      position: sticky;
      top: 0;
      max-height: 100vh;
      padding: 5.25rem 0 6rem;
      width: 42%;
      flex-shrink: 0;
    }
  }

  .sidebar-content {
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    height: 100%;
    gap: 1rem;
  }

  .header-section {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .logo-link {
    display: flex;
    flex-shrink: 0;
  }

  .name {
    margin: 0.4rem 0 0;
    font-family: var(--font-serif);
    font-style: italic;
    font-size: 2.5rem;
    font-weight: 400;
    letter-spacing: -0.025em;
    line-height: 1.1;
  }

  .name a {
    color: var(--text-primary);
    transition: color 0.2s ease-in-out;
  }

  .name a:hover {
    color: var(--accent);
  }

  .logo-mark {
    display: block;
    width: 36px;
    height: 36px;
    border-radius: 0.5rem;
    border: 1px solid var(--border);
    background-color: var(--bg);
    flex-shrink: 0;
  }

  .whoami {
    margin: 0.6rem 0 0;
    font-family: var(--font-mono);
    font-size: 0.8125rem;
    color: var(--text-secondary);
  }

  .tagline {
    margin: 0.15rem 0 0 0;
    font-family: var(--font-mono);
    font-size: 0.8125rem;
    font-weight: 400;
    color: var(--text-secondary);
    line-height: 1.5;
    max-width: 22rem;
  }

  .footer-section {
    margin-top: auto;
    display: flex;
    flex-direction: column;
    gap: 1.1rem;
  }

  .sb-cmdk {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    align-self: flex-start;
    padding: 0.4rem 0.7rem;
    background-color: var(--bg-elevated);
    border: 1px solid var(--border);
    border-radius: 7px;
    color: var(--text-tertiary);
    font-family: var(--font-mono);
    font-size: 0.78rem;
    cursor: pointer;
    transition:
      border-color 180ms ease,
      color 180ms ease;
  }

  .sb-cmdk:hover {
    border-color: var(--border-accent);
    color: var(--accent);
  }

  .footer-row {
    display: flex;
    align-items: center;
    gap: 1.5rem;
  }
</style>
